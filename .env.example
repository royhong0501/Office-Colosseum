# 複製為 .env 後填上實際值。docker compose 會自動讀取。

# Postgres（dev 預設由 docker compose 啟，使用者/密碼/db 都是 colosseum）
DATABASE_URL=postgresql://colosseum:colosseum@localhost:5432/colosseum

# Redis
REDIS_URL=redis://localhost:6379

# JWT 簽名密鑰（>= 16 字，建議用 32+ 字隨機字串）
# Linux/Mac: openssl rand -base64 48
# Windows: 隨意敲一串 32+ 字的字
JWT_SECRET=change-me-to-a-32-or-longer-random-string

# 第一個 admin 帳號（首次 prisma db:seed 才會建；之後不會重複建）
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-me-immediately
