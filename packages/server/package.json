{
  "name": "@office-colosseum/server",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@office-colosseum/shared": "*",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "dev": "node --env-file-if-exists=.env --watch src/index.js",
    "test": "node --env-file-if-exists=.env --test test/**/*.test.js",
    "smoke": "node --env-file=.env test/smoke.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "socket.io-client": "^4.8.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
