// Office Colosseum DB schema。
// User: 帳號（admin 發放）；Match / MatchParticipant: 戰績。
// 不再保留「最多 10 場」上限（DB 隨便存），查詢層分頁。

generator client {
  provider      = "prisma-client-js"
  // node:22-alpine 是 OpenSSL 3，不是 1.1；明確指定才會打對 binary
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PLAYER
}

enum ChatChannel {
  PUBLIC      // 大廳全站公頻
  ANNOUNCE    // 公告頻道（僅 ADMIN 可發訊）
  ROOM        // 房間頻道（roomId 必填，限該房內玩家 + 觀戰者可讀寫）
  DM          // 1-on-1 私訊
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(PLAYER)
  displayName  String
  disabled     Boolean  @default(false)
  createdById  String?
  createdBy    User?    @relation("Created", fields: [createdById], references: [id])
  created      User[]   @relation("Created")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  participants  MatchParticipant[]
  wonMatches    Match[]            @relation("Winner")
  sentChats     ChatMessage[]      @relation("ChatSender")
  receivedChats ChatMessage[]      @relation("ChatRecipient")
}

model Match {
  id           String   @id @default(cuid())
  gameType     String
  config       Json
  startedAt    DateTime
  endedAt      DateTime
  durationMs   Int
  winnerId     String?
  winner       User?    @relation("Winner", fields: [winnerId], references: [id])
  participants MatchParticipant[]
  createdAt    DateTime @default(now())

  @@index([gameType, endedAt])
}

model MatchParticipant {
  id            String  @id @default(cuid())
  matchId       String
  userId        String?
  characterId   String
  isBot         Boolean @default(false)
  displayName   String
  dmgDealt      Int
  dmgTaken      Int
  survivedTicks Int
  isWinner      Boolean
  // 遊戲專屬 stats：每款 gameType 各自的細部欄位（每 STAT_KEYS）。
  // BR: kills/bulletsFired/bulletsHit/dashUsed; Items: skillsCast/trapsPlaced/trapsTriggered/undoUsed/skill_*; Territory: cellsPainted/areasCaptured/teamCellsAtEnd/teamId
  stats         Json    @default("{}")
  match         Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user          User?   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([matchId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  channel     ChatChannel
  senderId    String
  sender      User        @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   User?       @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  // ROOM 頻道時必填；其他頻道為 null。 in-memory roomId（不對 FK，因為 Room 是 server runtime 物件）
  roomId      String?
  // 訊息回覆：reply 到同 channel 的另一則訊息
  replyToId   String?
  replyTo     ChatMessage?  @relation("ChatReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     ChatMessage[] @relation("ChatReply")
  content     String      @db.VarChar(500)
  // metadata JSON：目前存 { mentions: [userId, ...] }，將來可擴
  metadata    Json        @default("{}")
  createdAt   DateTime    @default(now())
  // 舊 boolean readAt（DM 用）保留 backward-compat；新功能改用 ChatMessageRead 表算 readByCount
  readAt      DateTime?
  reads       ChatMessageRead[]

  @@index([channel, createdAt])
  @@index([roomId, createdAt])
  @@index([recipientId, readAt])
  @@index([senderId, recipientId, createdAt])
}

// 已讀記錄：每則訊息每位讀者一筆，用 upsert 累計「已讀 N」
model ChatMessageRead {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([userId])
}
